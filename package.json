{
  "name": "mattq-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate && next build",
    "start": "next start",
    "deploy": "next build && touch out/.nojekyll && gh-pages -d out --dotfiles",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:routes": "node scripts/routes-generator.js",
    "generate:sitemap": "node scripts/sitemap-generator.js",
    "generate": "node scripts/routes-generator.js && node scripts/sitemap-generator.js"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.10.38",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "sitemap": "^9.0.1",
    "tailwind-merge": "^3.5.0",
    "xml-formatter": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "gh-pages": "^6.3.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  }
}
