{
  "name": "mattq-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate && next build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:rss": "node scripts/rss-generator.js",
    "generate:routes": "node scripts/routes-generator.js",
    "generate:sitemap": "node scripts/sitemap-generator.js",
    "generate": "npm run generate:rss && npm run generate:routes && npm run generate:sitemap",
    "predeploy": "npm run build",
    "deploy": "gh workflow run release.yml"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.10.38",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "next": "^16.1.7",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "reading-time": "^1.5.0",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "sitemap": "^9.0.1",
    "tailwind-merge": "^3.5.0",
    "xml-formatter": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "gh-pages": "^6.3.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  }
}
